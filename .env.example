# .env.example - template for required environment variables
# Copy to .env locally and fill in actual values.
# Never commit .env to git.

# Anthropic API key - for Haiku synthesis
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase configuration - for query logging
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Optional: override the model used for synthesis (default: claude-haiku-4-5)
# CLAUDE_MODEL=claude-haiku-4-5

# Optional: override the refusal threshold (default: 0.70)
# REFUSE_THRESHOLD=0.70